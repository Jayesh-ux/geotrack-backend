# --- Database Configuration ---
# Example: postgresql://username:password@localhost:5432/geotrack_local
DATABASE_URL=your_postgresql_connection_string

# --- Authentication & Security ---
JWT_SECRET=your_local_secret_key_for_testing
MIDDLEWARE_TOKEN=your_local_middleware_token

# --- Google Maps Integration ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_API_KEY1=your_google_maps_api_key

# --- Email Service (Gmail SMTP) ---
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
SENDER_EMAIL=your_email@gmail.com

# --- External API Keys ---
BREVO_API_KEY=your_brevo_api_key
LICENSE_WEBHOOK_SECRET=your_webhook_secret

# --- Environment ---
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
